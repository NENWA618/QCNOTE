# ==================== NextAuth.js 配置 ====================
# Frontend .env.local Configuration

# 应用 URL（部署域名）
# REQUIRED: 必须配置此项，NextAuth需要知道应用运行的UI地址
NEXTAUTH_URL=https://www.qcnote.com

# NextAuth Secret - 用于加密会话令牌
# REQUIRED: 在生产环境必须设置此项，使用强随机密钥
# 生成方法: openssl rand -base64 32
# SECURITY WARNING: 生产环境下不要使用默认值
NEXTAUTH_SECRET=your-secret-key-change-in-production

# 后端API URL（如使用独立后端）
# OPTIONAL: 如果有独立的后端服务器，填写其URL地址
BACKEND_URL=https://your-render-app.onrender.com

# 数据库配置
# OPTIONAL: PostgreSQL数据库连接字符串（用于存储用户数据）
DATABASE_URL=postgresql://username:password@localhost:5432/qcnote_db

# Redis 缓存配置
# OPTIONAL: Redis连接URL（用于会话存储和缓存）
REDIS_URL=redis://localhost:6379

# OAuth 提供商 - Google
# OPTIONAL: 配置Google登录功能
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth 提供商 - GitHub
# OPTIONAL: 配置GitHub登录功能
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth 提供商 - Discord
# OPTIONAL: 配置Discord登录功能
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# 应用环境
# development: 开发环境，启用详细日志
# production: 生产环境，优化性能和安全性
NODE_ENV=development

# 日志级别 (OPTIONAL)
# LOG_LEVEL=info

# API 速率限制 (OPTIONAL)
# API_RATE_LIMIT=100

# ==================== 后端环境变量 ====================
# 如果运行独立的Fastify后端服务器，需要配置:

PORT=10000
FRONTEND_URL=https://www.qcnote.com

# ==================== 如何获取 OAuth 密钥 ====================

## Google OAuth
# 1. 访问 https://console.cloud.google.com/
# 2. 创建新项目，启用 Google+ API
# 3. 配置 OAuth 同意屏幕
# 4. 创建 OAuth 2.0 凭证 (Web 应用类型)
# 5. 添加授权的重定向 URI: 
#    - 开发: http://localhost:3000/api/auth/callback/google
#    - 生产: https://www.qcnote.com/api/auth/callback/google
# 6. 复制 Client ID 和 Client Secret

## GitHub OAuth
# 1. 访问 https://github.com/settings/developers/new
# 2. 创建新 OAuth 应用
# 3. 填写回调 URL: https://www.qcnote.com/api/auth/callback/github
# 4. 生成 Personal Access Token，复制 Client ID 和 Client Secret

## Discord OAuth
# 1. 访问 https://discord.com/developers/applications
# 2. 创建新应用，进入OAuth2标签页
# 3. 设置重定向URL: https://www.qcnote.com/api/auth/callback/discord
# 4. 复制 Client ID 和 Client Secret

# ==================== 本地开发启动 ====================
# 1. 复制此文件为 .env.local
# 2. 填入至少必要的变量（NEXTAUTH_URL 和 NEXTAUTH_SECRET）
# 3. 运行: npm install && npm run dev
# 4. 访问: http://localhost:3000

# ==================== 生产环境部署 ====================
# 1. 设置所有必需的环境变量
# 2. 确保 NEXTAUTH_SECRET 是强随机密钥
# 3. 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 4. 在部署平台（Vercel、Render等）配置这些变量
# 5. 部署并测试OAuth流程
# 2. 创建新应用
# 3. 创建 OAuth2 凭证
# 4. 添加重定向 URL: https://www.qcnote.com/api/auth/callback/discord

# ==================== NEXTAUTH_SECRET 生成 ====================
# 在终端运行：
# openssl rand -base64 32
