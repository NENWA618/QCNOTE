# ==================== NextAuth.js 配置 ====================
# 前端 .env.local (Vercel)

# 应用 URL（Vercel 部署的域名）
NEXTAUTH_URL=https://www.qcnote.com
NEXTAUTH_SECRET=your-secret-key-change-in-production

# 后端 UGC API URL（Render 部署的域名）
BACKEND_URL=https://your-render-app.onrender.com

# OAuth 提供商 (Google)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth 提供商 (GitHub)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth 提供商 (Discord)
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# ==================== 后端 Render 环境变量 ====================
# server/.env 或 Render dashboard

# Node 环境
NODE_ENV=production

# 端口
PORT=10000

# Redis 连接（已在 Render 中配置）
REDIS_URL=redis://default:password@hostname:6379

# ==================== 如何获取 OAuth 密钥 ====================

## Google OAuth
# 1. 访问 https://console.cloud.google.com/
# 2. 创建新项目
# 3. 设置 OAuth 同意屏幕
# 4. 创建 OAuth 2.0 凭证 (Web 应用)
# 5. 添加授权的重定向 URI: https://www.qcnote.com/api/auth/callback/google

## GitHub OAuth
# 1. 访问 https://github.com/settings/developers
# 2. 创建新 OAuth 应用
# 3. 设置回调 URL: https://www.qcnote.com/api/auth/callback/github

## Discord OAuth
# 1. 访问 https://discord.com/developers/applications
# 2. 创建新应用
# 3. 创建 OAuth2 凭证
# 4. 添加重定向 URL: https://www.qcnote.com/api/auth/callback/discord

# ==================== NEXTAUTH_SECRET 生成 ====================
# 在终端运行：
# openssl rand -base64 32
